      family-names: Amara
      affiliation: Northern Border University
  title: >-
    AI-enhanced calibration of IoT particulate matter sensors in
    open-pit mining: a metrological approach to environmental
    cross-sensitivity compensation
  journal: Measurement
  publisher:
    name: Elsevier
  year: 2026
  notes: 'Manuscript MEAS-D-26-03768, under review (major revision).'
